# LocalRAG Backend — Environment Variables
# Copy to .env and fill in your values

# Storage
DATA_DIR=~/.localrag
VECTOR_BACKEND=qdrant        # qdrant | sqlite

# Providers
EMBEDDING_PROVIDER=auto      # auto | local | openai | ollama | gemini
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
LLM_PROVIDER=ollama          # ollama | openai | anthropic | gemini
LLM_MODEL=llama3.2

# Ollama (local, no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# API Keys (optional — only needed for cloud providers)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# Server
FRONTEND_URL=http://localhost:3000
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
